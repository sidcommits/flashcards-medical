# Copy to .env on the server (never commit real values)
PORT=3010
# 32+ random bytes, e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
COOKIE_SECRET=replace-with-random-hex
# Produced by: node scripts/hash-password.js 'her-password'
PASSWORD_HASH=salthex:hashhex
# Where the synced progress JSON lives
FC_DATA_FILE=/var/lib/flashcards-sync/progress.json
